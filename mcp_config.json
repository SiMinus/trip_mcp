{
  "mcpServers": {
    "weather": {
      "command": "python",
      "args": ["-m", "mcp_servers.weather_server"],
      "env": {"QWEATHER_API_KEY": "${QWEATHER_API_KEY}"}
    },
    "poi": {
      "command": "python",
      "args": ["-m", "mcp_servers.poi_server"]
    },
    "transport": {
      "command": "python",
      "args": ["-m", "mcp_servers.transport_server"]
    },
    "knowledge": {
      "command": "python",
      "args": ["-m", "mcp_servers.knowledge_server"]
    },
    "flight": {
      "command": "python",
      "args": ["-m", "mcp_servers.flight_server"]
    }
  }
}
